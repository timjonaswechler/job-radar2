{
  "schemaVersion": 1,
  "key": "ashby",
  "name": "Ashby",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [
      {
        "htmlRegex": "(?i)https?://(?:jobs\\.ashbyhq\\.com/|api\\.ashbyhq\\.com/posting-api/job-board/)([a-z0-9][a-z0-9_-]*)(?:/(?:embed|application|[^\\\"'<>\\s?]+))?(?:\\?[^\\\"'<>\\s]*)?",
        "captureAs": "boardSlug"
      }
    ]
  },
  "identity": {
    "keyCandidates": [
      "{{capture:companyWebsite|domainKey}}_careers",
      "{{capture:boardSlug|technicalKey}}_careers"
    ],
    "nameCandidates": [
      "{{capture:companyWebsite|domainTitle}} Karriere",
      "{{capture:boardSlug|titleCase}} Karriere"
    ],
    "optionalSourceConfig": {
      "companyWebsite": "{{capture:companyWebsite}}"
    }
  },
  "accessPaths": [
    {
      "key": "endpoint_inventory",
      "adapterKey": "declarative_endpoint_inventory",
      "availability": {
        "requiredCaptures": ["boardSlug"],
        "sourceConfig": {
          "startUrl": "https://api.ashbyhq.com/posting-api/job-board/{{capture:boardSlug}}?includeCompensation=true"
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["startUrl"],
        "properties": {
          "startUrl": {
            "type": "string",
            "format": "uri",
            "title": "Start-URL"
          },
          "companyWebsite": {
            "type": "string",
            "format": "uri",
            "title": "Firmen-Webseite"
          }
        }
      },
      "inventory": {
        "fetch": {
          "url": "{{sourceConfig:startUrl}}"
        },
        "parse": {
          "as": "json"
        },
        "items": {
          "select": {
            "jsonPath": "$.jobs"
          }
        },
        "fields": {
          "title": {
            "jsonPath": "$.title"
          },
          "url": {
            "jsonPath": "$.jobUrl"
          },
          "company": {
            "template": "{{sourceName}}"
          },
          "locations": [
            {
              "jsonPath": "$.location"
            }
          ]
        }
      }
    }
  ]
}
