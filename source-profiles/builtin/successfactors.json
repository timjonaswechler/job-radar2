{
  "schemaVersion": 1,
  "key": "successfactors",
  "name": "SAP SuccessFactors",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [
      {
        "htmlRegex": "(?is)(?:SAP\\s+SuccessFactors|SuccessFactors).*?(?:RMK|Recruiting\\s+Marketing|sap-rmk)|(?:RMK|Recruiting\\s+Marketing|sap-rmk).*?(?:SAP\\s+SuccessFactors|SuccessFactors)"
      },
      {
        "fetchText": {
          "url": "/sitemap.xml",
          "regex": "(?is)<urlset\\b[^>]*>.*<url>\\s*<loc>https?://[^<]+/job/[^<]+</loc>.*</url>.*</urlset>"
        }
      }
    ]
  },
  "accessPaths": [
    {
      "key": "sitemap_inventory",
      "adapterKey": "declarative_sitemap_inventory",
      "availability": {
        "sourceConfig": {
          "url": "{{origin}}/sitemap.xml",
          "recursive": false
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "title": "Sitemap-URL"
          },
          "recursive": {
            "type": "boolean",
            "default": false,
            "title": "Sitemap rekursiv auswerten"
          },
          "maxUrls": {
            "type": "number",
            "minimum": 1,
            "title": "Maximale URLs"
          }
        }
      },
      "inventory": {
        "fetch": {
          "url": "{{sourceConfig:url}}"
        },
        "parse": {
          "as": "xml"
        },
        "items": {
          "select": {
            "xmlText": "loc"
          },
          "where": [
            {
              "regex": "(?i)/job/"
            }
          ],
          "captures": [
            {
              "regex": "(?i)/job/(?P<location>[^/-]+)-(?P<title>.+?)(?:-\\d+)?(?:-\\d+)?/?$"
            }
          ]
        },
        "fields": {
          "title": {
            "template": "{{capture:title|urlDecode|slugToTitle}}"
          },
          "url": {
            "template": "{{itemText}}"
          },
          "company": {
            "template": "{{sourceName|stripCareerSuffix}}"
          },
          "locations": [
            {
              "template": "{{capture:location|urlDecode|slugToTitle}}"
            }
          ]
        }
      }
    }
  ]
}
