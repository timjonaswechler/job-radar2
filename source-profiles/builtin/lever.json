{
  "schemaVersion": 1,
  "key": "lever",
  "name": "Lever",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [
      {
        "htmlRegex": "(?i)https?://jobs\\.lever\\.co/[a-z0-9][^\\\"'<>\\s]*(?:/[a-z0-9][^\\\"'<>\\s]*)?"
      }
    ]
  },
  "accessPaths": [
    {
      "key": "endpoint_inventory",
      "adapterKey": "declarative_endpoint_inventory",
      "availability": {
        "sourceConfig": {
          "startUrl": "{{inputUrl}}"
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["startUrl"],
        "properties": {
          "startUrl": {
            "type": "string",
            "format": "uri",
            "title": "Start-URL"
          }
        }
      }
    }
  ]
}
