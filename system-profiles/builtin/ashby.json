{
  "key": "ashby",
  "name": "Ashby",
  "description": "Deklaratives HTTP-Systemprofil für Ashby-Boards und Ashby-Embeds.",
  "adapterKey": "declarative_http_jobboard",
  "definitionSchemaVersion": 1,
  "status": "active",
  "definition": {
    "detect": {
      "required": [
        {
          "htmlRegex": "(?i)https?://(?:jobs|api)\\.ashbyhq\\.com/(?:posting-api/job-board/)?[a-z0-9][^\\\"'<>\\s]*"
        }
      ]
    },
    "sourceConfig": {
      "startUrl": "{{inputUrl}}"
    }
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": ["startUrl"],
    "properties": {
      "startUrl": {
        "type": "string",
        "format": "uri",
        "title": "Start-URL"
      }
    }
  }
}
