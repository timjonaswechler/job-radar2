{
  "key": "lever",
  "name": "Lever",
  "description": "Deklaratives HTTP-Systemprofil für Lever-Boards und Lever-Postings.",
  "adapterKey": "declarative_http_jobboard",
  "definitionSchemaVersion": 1,
  "status": "active",
  "definition": {
    "detect": {
      "required": [
        {
          "htmlRegex": "(?i)https?://jobs\\.lever\\.co/[a-z0-9][^\\\"'<>\\s]*(?:/[a-z0-9][^\\\"'<>\\s]*)?"
        }
      ]
    },
    "sourceConfig": {
      "startUrl": "{{inputUrl}}"
    }
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": ["startUrl"],
    "properties": {
      "startUrl": {
        "type": "string",
        "format": "uri",
        "title": "Start-URL"
      }
    }
  }
}
