{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/source.schema.json",
  "title": "Job Radar Source DSL document",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "key", "name", "status", "sourceConfig", "selectedAccessPath"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "key": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
    "name": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
    "status": { "$ref": "profile-dsl/common.schema.json#/$defs/sourceStatus" },
    "sourceConfig": { "$ref": "profile-dsl/common.schema.json#/$defs/jsonObject" },
    "selectedAccessPath": {
      "oneOf": [
        { "$ref": "#/$defs/profileAccessPathSelection" },
        { "$ref": "#/$defs/sourceOwnedAccessPath" }
      ]
    },
    "sourceOverrides": { "$ref": "profile-dsl/overrides.schema.json#/$defs/sourceOverrides" },
    "sourceSupport": { "$ref": "profile-dsl/common.schema.json#/$defs/supportMetadata" },
    "diagnostics": { "$ref": "profile-dsl/diagnostics.schema.json#/$defs/diagnostics" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "selectedAccessPath": {
            "properties": { "type": { "const": "profile_access_path" } },
            "required": ["type"]
          }
        },
        "required": ["selectedAccessPath"]
      },
      "then": {
        "not": { "required": ["sourceSupport"] }
      }
    },
    {
      "if": {
        "properties": {
          "selectedAccessPath": {
            "properties": { "type": { "const": "source_owned_access_path" } },
            "required": ["type"]
          }
        },
        "required": ["selectedAccessPath"]
      },
      "then": {
        "required": ["sourceSupport"],
        "not": { "required": ["sourceOverrides"] }
      }
    }
  ],
  "$defs": {
    "profileAccessPathSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "profileKey", "pathKey"],
      "properties": {
        "type": { "const": "profile_access_path" },
        "profileKey": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
        "pathKey": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" }
      }
    },
    "sourceOwnedAccessPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "key", "name", "postingDiscovery"],
      "properties": {
        "type": { "const": "source_owned_access_path" },
        "key": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
        "name": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "description": { "$ref": "profile-dsl/common.schema.json#/$defs/description" },
        "sourceConfigSchema": { "$ref": "profile-dsl/common.schema.json#/$defs/jsonSchemaObject" },
        "postingDiscovery": { "$ref": "profile-dsl/strategy.schema.json#/$defs/postingDiscoveryStep" },
        "postingDetail": { "$ref": "profile-dsl/strategy.schema.json#/$defs/postingDetailStep" },
        "diagnostics": { "$ref": "profile-dsl/diagnostics.schema.json#/$defs/diagnostics" }
      }
    }
  }
}
