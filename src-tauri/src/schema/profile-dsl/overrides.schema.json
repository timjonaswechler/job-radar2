{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/profile-dsl/overrides.schema.json",
  "title": "Job Radar Profile DSL source override definitions",
  "$defs": {
    "sourceOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategyOverrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/strategyOverride" }
        }
      }
    },
    "strategyOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "strategyKey"],
      "properties": {
        "step": { "type": "string", "enum": ["postingDiscovery", "postingDetail"] },
        "strategyKey": { "$ref": "common.schema.json#/$defs/technicalKey" },
        "fetch": { "$ref": "fetch.schema.json#/$defs/fetch" },
        "select": { "$ref": "select.schema.json#/$defs/select" },
        "extract": {
          "type": "object",
          "additionalProperties": { "$ref": "extract.schema.json#/$defs/fieldExpression" }
        },
        "transforms": { "$ref": "transform.schema.json#/$defs/transforms" },
        "acceptWhen": { "$ref": "strategy.schema.json#/$defs/acceptance" }
      }
    }
  }
}
