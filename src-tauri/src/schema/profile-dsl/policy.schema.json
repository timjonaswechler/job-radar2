{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/profile-dsl/policy.schema.json",
  "title": "Job Radar schema-v3 Strategy Policy definitions",
  "oneOf": [
    { "$ref": "#/$defs/discoveryStrategySet" },
    { "$ref": "#/$defs/detailStrategySet" }
  ],
  "$defs": {
    "strategyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["first_accepted", "all_required"] }
      }
    },
    "phaseLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxStrategyAttempts", "maxRequests", "maxProducedItems", "maxDurationMs", "maxPages", "maxBrowserActions", "maxFanOut", "maxResponseBytes"],
      "properties": {
        "maxStrategyAttempts": { "type": "integer", "minimum": 1, "maximum": 50 },
        "maxRequests": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "maxProducedItems": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "maxDurationMs": { "type": "integer", "minimum": 1, "maximum": 120000 },
        "maxPages": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "maxBrowserActions": { "type": "integer", "minimum": 1, "maximum": 50 },
        "maxFanOut": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "maxResponseBytes": { "type": "integer", "minimum": 1, "maximum": 67108864 }
      }
    },
    "discoveryStrategySet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "strategies"],
      "properties": {
        "policy": { "$ref": "#/$defs/strategyPolicy" },
        "strategies": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "strategy.schema.json#/$defs/discoveryStrategy" }
        },
        "limits": { "$ref": "#/$defs/phaseLimits" },
        "acceptWhen": { "$ref": "strategy.schema.json#/$defs/acceptance" }
      }
    },
    "detailStrategySet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "strategies"],
      "properties": {
        "policy": { "$ref": "#/$defs/strategyPolicy" },
        "strategies": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "strategy.schema.json#/$defs/detailStrategy" }
        },
        "limits": { "$ref": "#/$defs/phaseLimits" },
        "acceptWhen": { "$ref": "strategy.schema.json#/$defs/acceptance" }
      }
    }
  }
}
