{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/profile-dsl/policy.schema.json",
  "title": "Job Radar schema-v3 Strategy Policy definitions",
  "oneOf": [
    { "$ref": "#/$defs/discoveryStrategySet" },
    { "$ref": "#/$defs/detailStrategySet" }
  ],
  "$defs": {
    "strategyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "first_accepted" }
      }
    },
    "discoveryStrategySet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "strategies"],
      "properties": {
        "policy": { "$ref": "#/$defs/strategyPolicy" },
        "strategies": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "strategy.schema.json#/$defs/discoveryStrategy" }
        },
        "acceptWhen": { "$ref": "strategy.schema.json#/$defs/acceptance" }
      }
    },
    "detailStrategySet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "strategies"],
      "properties": {
        "policy": { "$ref": "#/$defs/strategyPolicy" },
        "strategies": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "strategy.schema.json#/$defs/detailStrategy" }
        },
        "acceptWhen": { "$ref": "strategy.schema.json#/$defs/acceptance" }
      }
    }
  }
}
