{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/profile-dsl/transform.schema.json",
  "title": "Job Radar Profile DSL transform definitions",
  "$defs": {
    "transforms": {
      "type": "array",
      "items": { "$ref": "#/$defs/transform" }
    },
    "transform": {
      "oneOf": [
        { "$ref": "#/$defs/simpleTransform" },
        { "$ref": "#/$defs/splitTransform" },
        { "$ref": "#/$defs/joinTransform" },
        { "$ref": "#/$defs/regexReplaceTransform" }
      ]
    },
    "simpleTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "trim",
            "normalize_whitespace",
            "html_to_text",
            "url_decode",
            "slug_to_title",
            "dedupe",
            "to_string"
          ]
        }
      }
    },
    "splitTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "separator"],
      "properties": {
        "type": { "const": "split" },
        "separator": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "trimParts": { "type": "boolean" },
        "dropEmpty": { "type": "boolean" }
      }
    },
    "joinTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "separator"],
      "properties": {
        "type": { "const": "join" },
        "separator": { "type": "string" }
      }
    },
    "regexReplaceTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "pattern", "replacement"],
      "properties": {
        "type": { "const": "regex_replace" },
        "pattern": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "replacement": { "type": "string" }
      }
    }
  }
}
