{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/profile-dsl/diagnostics.schema.json",
  "title": "Job Radar Profile DSL diagnostics",
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "error"]
    },
    "diagnosticCategory": {
      "type": "string",
      "enum": ["schema", "registry", "compiler", "runtime", "detection", "source_validation"]
    },
    "jsonPointer": {
      "type": "string",
      "pattern": "^($|/)"
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "code", "message", "severity", "path"],
      "properties": {
        "category": { "$ref": "#/$defs/diagnosticCategory" },
        "code": { "$ref": "common.schema.json#/$defs/technicalKey" },
        "message": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "severity": { "$ref": "#/$defs/severity" },
        "path": { "$ref": "#/$defs/jsonPointer" },
        "strategyKey": { "$ref": "common.schema.json#/$defs/technicalKey" },
        "details": { "$ref": "common.schema.json#/$defs/jsonObject" }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    }
  }
}
