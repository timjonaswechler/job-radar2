{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://job-radar.local/schemas/source-profile.schema.json",
  "title": "Job Radar Source Profile DSL document",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "key", "name", "kind", "support", "accessPaths"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "key": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
    "name": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
    "kind": {
      "type": "string",
      "enum": ["recruiting_system", "job_portal", "website_family", "career_site", "generic"]
    },
    "description": { "$ref": "profile-dsl/common.schema.json#/$defs/description" },
    "support": { "$ref": "profile-dsl/common.schema.json#/$defs/supportMetadata" },
    "detect": { "$ref": "#/$defs/detection" },
    "sourceConfigSchema": { "$ref": "profile-dsl/common.schema.json#/$defs/jsonSchemaObject" },
    "accessPaths": {
      "type": "array",
      "items": { "$ref": "#/$defs/profileAccessPath" }
    },
    "diagnostics": { "$ref": "profile-dsl/diagnostics.schema.json#/$defs/diagnostics" }
  },
  "$defs": {
    "profileAccessPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "name", "postingDiscovery"],
      "properties": {
        "key": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
        "name": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "description": { "$ref": "profile-dsl/common.schema.json#/$defs/description" },
        "sourceConfigSchema": { "$ref": "profile-dsl/common.schema.json#/$defs/jsonSchemaObject" },
        "knownIssues": {
          "type": "array",
          "items": { "$ref": "profile-dsl/common.schema.json#/$defs/supportNote" }
        },
        "postingDiscovery": { "$ref": "profile-dsl/strategy.schema.json#/$defs/postingDiscoveryStep" },
        "postingDetail": { "$ref": "profile-dsl/strategy.schema.json#/$defs/postingDetailStep" },
        "diagnostics": { "$ref": "profile-dsl/diagnostics.schema.json#/$defs/diagnostics" }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputUrlPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/inputUrlPattern" }
        },
        "recommendedAccessPathKey": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
        "sourceConfig": { "$ref": "profile-dsl/common.schema.json#/$defs/jsonObject" },
        "keyCandidates": {
          "type": "array",
          "items": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" }
        },
        "nameCandidates": {
          "type": "array",
          "items": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" }
        },
        "httpChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/detectionHttpCheck" }
        },
        "browserProbes": {
          "type": "array",
          "items": { "$ref": "#/$defs/detectionBrowserProbe" }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/detectionEvidence" }
        }
      }
    },
    "inputUrlPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern"],
      "properties": {
        "pattern": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "captures": {
          "type": "array",
          "items": { "$ref": "profile-dsl/common.schema.json#/$defs/captureKey" }
        }
      }
    },
    "detectionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": { "type": "string", "enum": ["url", "http", "html", "browser"] },
        "message": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "path": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "detectionHttpCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "url", "timeoutMs"],
      "properties": {
        "key": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
        "url": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "expectStatus": { "type": "integer", "minimum": 100, "maximum": 599 },
        "contains": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "regex": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "evidence": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "detectionBrowserProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "url", "timeoutMs"],
      "properties": {
        "key": { "$ref": "profile-dsl/common.schema.json#/$defs/technicalKey" },
        "url": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "waits": {
          "type": "array",
          "items": { "$ref": "profile-dsl/fetch.schema.json#/$defs/browserWait" }
        },
        "interactions": {
          "type": "array",
          "items": { "$ref": "#/$defs/detectionBrowserInteraction" }
        },
        "htmlContains": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "htmlRegex": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "evidence": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "detectionBrowserInteraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "selector", "maxCount"],
      "properties": {
        "type": { "type": "string", "enum": ["click_if_visible", "click_until_gone"] },
        "selector": { "$ref": "profile-dsl/common.schema.json#/$defs/nonEmptyString" },
        "maxCount": { "type": "integer", "minimum": 1 },
        "waitAfterMs": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
