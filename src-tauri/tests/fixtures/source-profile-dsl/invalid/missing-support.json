{
  "schemaVersion": 3,
  "key": "missing_support_profile",
  "name": "Missing Support Profile",
  "kind": "generic",
  "accessPaths": [
    {
      "key": "json_feed",
      "name": "JSON feed",
      "discovery": {
        "strategies": [
          {
            "key": "json_api",
            "fetch": {
              "mode": "http",
              "url": "https://example.test/jobs",
              "timeoutMs": 10000
            },
            "parse": {
              "type": "json"
            },
            "select": {
              "type": "json_path",
              "jsonPath": "$.jobs"
            },
            "extract": {
              "reference": {
                "url": {
                  "type": "json_path",
                  "jsonPath": "$.url"
                }
              },
              "providerValues": {
                "title": {
                  "type": "json_path",
                  "jsonPath": "$.title"
                },
                "company": {
                  "type": "const",
                  "value": "Example"
                }
              }
            }
          }
        ],
        "policy": {
          "type": "first_accepted"
        }
      }
    }
  ]
}
