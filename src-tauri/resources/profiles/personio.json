{
  "schemaVersion": 1,
  "key": "personio",
  "name": "Personio",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [],
    "anyOf": [
      [
        {
          "inputUrlRegex": "(?i)^https?://([a-z0-9][a-z0-9-]*\\.jobs\\.personio\\.(?:de|com))(?:[/:?#]|$)",
          "captureAs": "personioHost"
        },
        {
          "inputUrlRegex": "(?i)^https?://([a-z0-9][a-z0-9-]*)\\.jobs\\.personio\\.(?:de|com)(?:[/:?#]|$)",
          "captureAs": "boardSlug"
        },
        {
          "fetchText": {
            "url": "/xml?language=en",
            "regex": "(?is)<workzag-jobs\\b"
          }
        }
      ],
      [
        {
          "htmlRegex": "(?i)https?://([a-z0-9][a-z0-9-]*\\.jobs\\.personio\\.(?:de|com))(?:[/?#&\\\"'<>\\s]|$)",
          "captureAs": "personioHost"
        },
        {
          "htmlRegex": "(?i)https?://([a-z0-9][a-z0-9-]*)\\.jobs\\.personio\\.(?:de|com)(?:[/?#&\\\"'<>\\s]|$)",
          "captureAs": "boardSlug"
        }
      ]
    ]
  },
  "identity": {
    "keyCandidates": [
      "{{capture:boardSlug|technicalKey}}"
    ],
    "nameCandidates": [
      "{{capture:boardSlug|titleCase}}"
    ]
  },
  "accessPaths": [
    {
      "key": "endpoint_inventory",
      "name": "Personio XML feed",
      "adapterKey": "declarative_endpoint_inventory",
      "availability": {
        "requiredCaptures": ["boardSlug", "personioHost"],
        "sourceConfig": {
          "boardSlug": "{{capture:boardSlug}}",
          "personioHost": "{{capture:personioHost}}",
          "language": "en",
          "startUrl": "{{inputUrl}}"
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["boardSlug", "personioHost", "language"],
        "additionalProperties": false,
        "properties": {
          "boardSlug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "title": "Personio tenant"
          },
          "personioHost": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*\\.jobs\\.personio\\.(de|com)$",
            "title": "Personio jobs host"
          },
          "language": {
            "type": "string",
            "enum": ["de", "en", "fr", "es", "nl", "it", "pt"],
            "default": "en",
            "title": "Feed language"
          },
          "startUrl": {
            "type": "string",
            "format": "uri",
            "title": "Start-URL"
          }
        }
      },
      "inventory": {
        "fetch": {
          "url": "https://{{sourceConfig:personioHost}}/xml?language={{sourceConfig:language}}"
        },
        "parse": {
          "as": "xml"
        },
        "items": {
          "select": {
            "xmlElement": "position"
          }
        },
        "fields": {
          "title": {
            "jsonPath": "$.name"
          },
          "url": {
            "template": "https://{{sourceConfig:personioHost}}/job/{{itemJson:$.id}}"
          },
          "company": {
            "template": "{{sourceName}}"
          },
          "locations": [
            {
              "jsonPath": "$.office"
            },
            {
              "jsonPath": "$.additionalOffices.office"
            }
          ]
        }
      }
    }
  ]
}
