{
  "schemaVersion": 1,
  "key": "muz_global_jobboard",
  "name": "Milch & Zucker Global Jobboard",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [
      {
        "htmlRegex": "(?is)class=[\"'][^\"']*jobboard-widget[^\"']*[\"'][^>]+data-widget=[\"']jobboard[A-Za-z]+[\"']"
      },
      {
        "fetchScript": {
          "srcRegex": "(?i)(^|/)script/gjb_scripts\\.js(?:\\?.*)?$",
          "regex": "gjbAddress\\s*=\\s*\"([^\"]+)\"",
          "captureAs": "apiBaseUrl"
        }
      },
      {
        "fetchJson": {
          "url": "/assets/js/jobboard.config.json",
          "pathExists": "$.configWidgetContainer.search"
        }
      }
    ]
  },
  "accessPaths": [
    {
      "key": "endpoint_inventory",
      "adapterKey": "declarative_endpoint_inventory",
      "availability": {
        "requiredCaptures": ["apiBaseUrl"],
        "sourceConfig": {
          "startUrl": "{{inputUrl}}",
          "apiBaseUrl": "{{capture:apiBaseUrl}}",
          "configUrl": "{{origin}}/assets/js/jobboard.config.json"
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["startUrl", "apiBaseUrl", "configUrl"],
        "additionalProperties": false,
        "properties": {
          "startUrl": {
            "type": "string",
            "format": "uri",
            "title": "Start-URL"
          },
          "apiBaseUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://.+/$",
            "title": "API-Basis-URL"
          },
          "configUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://.+/assets/js/jobboard\\.config\\.json$",
            "title": "Jobboard-Konfiguration"
          }
        }
      },
      "inventory": {
        "fetch": {
          "url": "{{sourceConfig:apiBaseUrl}}search/"
        },
        "parse": {
          "as": "json"
        },
        "items": {
          "select": {
            "jsonPath": "$.SearchResult.SearchResultItems"
          }
        },
        "fields": {
          "title": {
            "jsonPath": "$.MatchedObjectDescriptor.PositionTitle"
          },
          "url": {
            "jsonPath": "$.MatchedObjectDescriptor.PositionURI"
          },
          "company": {
            "template": "{{sourceName}}"
          },
          "locations": [
            {
              "jsonPath": "$.MatchedObjectDescriptor.PositionLocation",
              "objectFields": ["CityName", "CountryName"]
            }
          ],
          "postingMeta": {
            "jobId": {
              "jsonPath": "$.MatchedObjectId"
            }
          }
        }
      },
      "postingDetail": {
        "fetch": {
          "url": "{{sourceConfig:apiBaseUrl}}search/%7B%22JobadID%22%3A%22{{postingMeta:jobId}}%22%2C%22SearchParamters%22%3A%7B%22FirstItem%22%3A1%2C%22CountItem%22%3A1%7D%7D.json"
        },
        "parse": {
          "as": "json"
        },
        "items": {
          "select": {
            "jsonPath": "$.SearchResult.SearchResultItems"
          }
        },
        "match": {
          "field": {
            "jsonPath": "$.MatchedObjectId"
          },
          "equals": "{{postingMeta:jobId}}"
        },
        "fields": {
          "descriptionText": {
            "jsonPathHtml": "$.MatchedObjectDescriptor.UserArea.TextJobDescription"
          }
        }
      }
    }
  ]
}
