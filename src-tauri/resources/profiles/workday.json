{
  "schemaVersion": 2,
  "key": "workday",
  "name": "Workday Recruiting",
  "kind": "recruiting_system",
  "description": "Workday CXS public careers API profile for HTTP POST posting discovery and lazy posting detail extraction.",
  "support": {
    "level": "verified",
    "summary": "Verified against deterministic offline Workday CXS-compatible discovery, offset/limit pagination, and detail fixtures.",
    "evidence": [
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/workday/posting-discovery-page-0-response.json",
        "summary": "postingDiscovery fixture executes CXS POST discovery through the public Profile Compiler and shared Profile DSL runtime."
      },
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/workday/posting-discovery-page-2-response.json",
        "summary": "postingDiscovery fixture exercises bounded offset/limit pagination through JSON request body parameters."
      },
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/workday/posting-detail-jr-1001-response.json",
        "summary": "postingDetail fixture extracts normalized descriptionText from Workday CXS HTML-in-JSON content through the shared Profile DSL runtime."
      }
    ]
  },
  "detect": {
    "recommendedAccessPathKey": "cxs_api",
    "sourceConfig": {
      "workdayHost": "{{capture:workdayHost}}",
      "tenant": "{{capture:tenant}}",
      "site": "{{capture:site}}",
      "startUrl": "{{inputUrl}}"
    },
    "keyCandidates": ["workday_{{capture:tenant}}_{{capture:site}}"],
    "nameCandidates": ["Workday {{capture:tenant}} {{capture:site}}"],
    "inputUrlPatterns": [
      {
        "pattern": "(?i)^https?://(?<workdayHost>(?<tenant>[A-Za-z0-9_-]+)\\.wd[0-9]+\\.myworkdayjobs\\.com)(?:/[a-z]{2}-[A-Z]{2})?/(?<site>[A-Za-z0-9_-]+)(?:[/?#].*)?$",
        "captures": ["workdayHost", "tenant", "site"]
      },
      {
        "pattern": "(?i)^https?://(?<workdayHost>[A-Za-z0-9.-]+\\.myworkdayjobs\\.com)/wday/cxs/(?<tenant>[A-Za-z0-9_-]+)/(?<site>[A-Za-z0-9_-]+)(?:/jobs|/job/.*)?(?:[?#].*)?$",
        "captures": ["workdayHost", "tenant", "site"]
      }
    ],
    "evidence": [
      {
        "kind": "url",
        "message": "Workday public career URLs expose a myworkdayjobs host and site path; common tenant-host forms expose the tenant prefix."
      },
      {
        "kind": "url",
        "message": "Workday CXS API URLs expose host, tenant, and site path segments for a source-config proposal."
      }
    ]
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": ["workdayHost", "tenant", "site"],
    "additionalProperties": false,
    "properties": {
      "workdayHost": {
        "type": "string",
        "pattern": "^[A-Za-z0-9.-]+\\.myworkdayjobs\\.com$",
        "title": "Workday host"
      },
      "tenant": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$",
        "title": "Workday tenant"
      },
      "site": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$",
        "title": "Workday site"
      },
      "startUrl": {
        "type": "string",
        "format": "uri",
        "title": "Start URL"
      }
    }
  },
  "accessPaths": [
    {
      "key": "cxs_api",
      "name": "Workday CXS API",
      "description": "Discover jobs from POST /wday/cxs/{tenant}/{site}/jobs and load one posting from GET /wday/cxs/{tenant}/{site}{externalPath}.",
      "postingDiscovery": {
        "strategies": [
          {
            "key": "cxs_jobs_api",
            "fetch": {
              "mode": "http",
              "method": "POST",
              "url": "https://{{sourceConfig:workdayHost}}/wday/cxs/{{sourceConfig:tenant}}/{{sourceConfig:site}}/jobs",
              "headers": {
                "accept": "application/json",
                "content-type": "application/json"
              },
              "body": {
                "type": "json",
                "value": {
                  "appliedFacets": {},
                  "limit": 0,
                  "offset": 0
                }
              },
              "timeoutMs": 10000
            },
            "pagination": {
              "type": "offset_limit",
              "offsetParam": "offset",
              "limitParam": "limit",
              "parameterLocation": "json_body",
              "startOffset": 0,
              "limit": 2,
              "totalPath": "$.total",
              "limits": { "maxRequests": 2 }
            },
            "parse": { "type": "json" },
            "select": {
              "type": "json_path",
              "jsonPath": "$.jobPostings"
            },
            "extract": {
              "fields": {
                "title": {
                  "type": "json_path",
                  "jsonPath": "$.title",
                  "cardinality": "one",
                  "transforms": [{ "type": "trim" }]
                },
                "company": {
                  "type": "template",
                  "template": "{{source:name}}",
                  "cardinality": "one"
                },
                "url": {
                  "type": "combine",
                  "join": "",
                  "cardinality": "one",
                  "parts": [
                    { "value": { "type": "const", "value": "https://" } },
                    { "value": { "type": "source_config", "key": "workdayHost", "cardinality": "one" } },
                    { "value": { "type": "const", "value": "/en-US/" } },
                    { "value": { "type": "source_config", "key": "site", "cardinality": "one" } },
                    { "value": { "type": "json_path", "jsonPath": "$.externalPath", "cardinality": "one" } }
                  ]
                },
                "locations": {
                  "type": "json_path",
                  "jsonPath": "$.locationsText",
                  "cardinality": "optional",
                  "transforms": [{ "type": "trim" }]
                },
                "postingMeta": {
                  "externalPath": {
                    "type": "json_path",
                    "jsonPath": "$.externalPath",
                    "cardinality": "one"
                  }
                }
              }
            },
            "acceptWhen": {
              "requiredFields": ["title", "company", "url", "postingMeta.externalPath"],
              "minResults": 1
            }
          }
        ]
      },
      "postingDetail": {
        "strategies": [
          {
            "key": "cxs_job_detail_api",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "https://{{sourceConfig:workdayHost}}/wday/cxs/{{sourceConfig:tenant}}/{{sourceConfig:site}}{{postingMeta:externalPath}}",
              "headers": {
                "accept": "application/json"
              },
              "timeoutMs": 10000
            },
            "parse": { "type": "json" },
            "select": { "type": "document" },
            "extract": {
              "fields": {
                "descriptionText": {
                  "type": "json_path",
                  "jsonPath": "$.jobPostingInfo.jobDescription",
                  "cardinality": "one",
                  "transforms": [
                    { "type": "html_to_text" },
                    { "type": "normalize_whitespace" }
                  ]
                }
              }
            },
            "acceptWhen": {
              "minDescriptionLength": 20
            }
          }
        ]
      }
    }
  ]
}
