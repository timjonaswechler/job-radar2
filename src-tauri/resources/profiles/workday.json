{
  "schemaVersion": 3,
  "key": "workday",
  "name": "Workday Recruiting",
  "kind": "recruiting_system",
  "description": "Workday CXS public careers API profile for HTTP POST posting discovery and lazy posting detail extraction.",
  "support": {
    "level": "stable",
    "summary": "Maintained built-in Workday CXS-compatible profile. Use Source Live Check on concrete Sources for current operational confidence.",
    "evidence": [
      {
        "kind": "manual_review",
        "reference": "Workday CXS public career site patterns",
        "summary": "Public CXS discovery and detail extraction patterns are modeled by the built-in profile."
      }
    ]
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": [
      "workdayHost",
      "tenant",
      "site"
    ],
    "additionalProperties": false,
    "properties": {
      "workdayHost": {
        "type": "string",
        "pattern": "^[A-Za-z0-9.-]+\\.myworkdayjobs\\.com$",
        "title": "Workday host"
      },
      "tenant": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$",
        "title": "Workday tenant"
      },
      "site": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$",
        "title": "Workday site"
      },
      "startUrl": {
        "type": "string",
        "format": "uri",
        "title": "Start URL"
      }
    }
  },
  "accessPaths": [
    {
      "key": "cxs_api",
      "name": "Workday CXS API",
      "description": "Discover jobs from POST /wday/cxs/{tenant}/{site}/jobs and load one posting from GET /wday/cxs/{tenant}/{site}{externalPath}.",
      "discovery": {
        "strategies": [
          {
            "key": "cxs_jobs_api",
            "fetch": {
              "mode": "http",
              "method": "POST",
              "url": "https://{{sourceConfig:workdayHost}}/wday/cxs/{{sourceConfig:tenant}}/{{sourceConfig:site}}/jobs",
              "headers": {
                "accept": "application/json",
                "content-type": "application/json"
              },
              "body": {
                "type": "json",
                "value": {
                  "appliedFacets": {},
                  "limit": 0,
                  "offset": 0
                }
              },
              "timeoutMs": 10000
            },
            "pagination": {
              "type": "offset_limit",
              "offsetParam": "offset",
              "limitParam": "limit",
              "parameterLocation": "json_body",
              "startOffset": 0,
              "limit": 20,
              "totalPath": "$.total",
              "limits": {
                "maxRequests": 100
              }
            },
            "parse": {
              "type": "json"
            },
            "select": {
              "type": "json_path",
              "jsonPath": "$.jobPostings"
            },
            "extract": {
              "reference": {
                "url": {
                  "type": "combine",
                  "join": "",
                  "cardinality": "one",
                  "parts": [
                    {
                      "value": {
                        "type": "const",
                        "value": "https://"
                      }
                    },
                    {
                      "value": {
                        "type": "source_config",
                        "key": "workdayHost",
                        "cardinality": "one"
                      }
                    },
                    {
                      "value": {
                        "type": "const",
                        "value": "/en-US/"
                      }
                    },
                    {
                      "value": {
                        "type": "source_config",
                        "key": "site",
                        "cardinality": "one"
                      }
                    },
                    {
                      "value": {
                        "type": "json_path",
                        "jsonPath": "$.externalPath",
                        "cardinality": "one"
                      }
                    }
                  ]
                },
                "providerPostingId": {
                  "type": "json_path",
                  "jsonPath": "$.externalPath",
                  "cardinality": "one"
                }
              },
              "providerValues": {
                "title": {
                  "type": "json_path",
                  "jsonPath": "$.title",
                  "cardinality": "one",
                  "transforms": [
                    {
                      "type": "to_string"
                    },
                    {
                      "type": "trim"
                    }
                  ]
                },
                "company": {
                  "type": "template",
                  "template": "{{source:name}}",
                  "cardinality": "one"
                },
                "locations": {
                  "type": "json_path",
                  "jsonPath": "$.locationsText",
                  "cardinality": "optional",
                  "transforms": [
                    {
                      "type": "to_string"
                    },
                    {
                      "type": "trim"
                    }
                  ]
                }
              },
              "postingMeta": {
                "externalPath": {
                  "type": "json_path",
                  "jsonPath": "$.externalPath",
                  "cardinality": "one"
                }
              }
            },
            "acceptWhen": {
              "requiredFields": [
                "title",
                "company",
                "url",
                "postingMeta.externalPath"
              ],
              "minResults": 1
            }
          }
        ],
        "policy": {
          "type": "first_accepted"
        }
      },
      "detail": {
        "strategies": [
          {
            "key": "cxs_job_detail_api",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "https://{{sourceConfig:workdayHost}}/wday/cxs/{{sourceConfig:tenant}}/{{sourceConfig:site}}{{postingMeta:externalPath}}",
              "headers": {
                "accept": "application/json"
              },
              "timeoutMs": 10000
            },
            "parse": {
              "type": "json"
            },
            "select": {
              "type": "document"
            },
            "extract": {
              "fields": {
                "descriptionText": {
                  "type": "json_path",
                  "jsonPath": "$.jobPostingInfo.jobDescription",
                  "cardinality": "one",
                  "transforms": [
                    {
                      "type": "to_string"
                    },
                    {
                      "type": "html_to_text"
                    },
                    {
                      "type": "normalize_whitespace"
                    }
                  ]
                }
              }
            },
            "acceptWhen": {
              "minDescriptionLength": 20
            }
          }
        ],
        "policy": {
          "type": "first_accepted"
        }
      }
    }
  ],
  "detection": {
    "recommendedAccessPathKey": "cxs_api",
    "sourceConfig": {
      "workdayHost": "{{capture:workdayHost}}",
      "tenant": "{{capture:tenant}}",
      "site": "{{capture:site}}",
      "startUrl": "{{inputUrl}}"
    },
    "keyCandidates": [
      "workday_{{capture:tenant}}_{{capture:site}}"
    ],
    "nameCandidates": [
      "Workday {{capture:tenant}} {{capture:site}}"
    ],
    "inputUrlPatterns": [
      {
        "pattern": "(?i)^https?://(?<workdayHost>(?<tenant>[A-Za-z0-9_-]+)\\.wd[0-9]+\\.myworkdayjobs\\.com)(?:/[a-z]{2}-[A-Z]{2})?/(?<site>[A-Za-z0-9_-]+)(?:[/?#].*)?$",
        "captures": [
          "workdayHost",
          "tenant",
          "site"
        ]
      },
      {
        "pattern": "(?i)^https?://(?<workdayHost>[A-Za-z0-9.-]+\\.myworkdayjobs\\.com)/wday/cxs/(?<tenant>[A-Za-z0-9_-]+)/(?<site>[A-Za-z0-9_-]+)(?:/jobs|/job/.*)?(?:[?#].*)?$",
        "captures": [
          "workdayHost",
          "tenant",
          "site"
        ]
      }
    ],
    "evidence": [
      {
        "kind": "url",
        "message": "Workday public career URLs expose a myworkdayjobs host and site path; common tenant-host forms expose the tenant prefix."
      },
      {
        "kind": "url",
        "message": "Workday CXS API URLs expose host, tenant, and site path segments for a source-config proposal."
      }
    ]
  }
}
