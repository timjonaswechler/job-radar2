{
  "schemaVersion": 2,
  "key": "successfactors",
  "name": "SAP SuccessFactors",
  "kind": "recruiting_system",
  "description": "SAP SuccessFactors Recruiting Marketing sitemap profile for XML posting discovery and lazy HTML detail extraction with ordered fallback selectors.",
  "support": {
    "level": "verified",
    "summary": "Verified against deterministic offline SAP SuccessFactors/RMK-compatible sitemap discovery and HTML detail fixtures.",
    "evidence": [
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/successfactors/posting-discovery-sitemap.xml",
        "summary": "postingDiscovery fixture executes bounded sitemap/XML discovery through the public Profile Compiler and shared Profile DSL runtime."
      },
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/successfactors/posting-detail-1001-primary.html",
        "summary": "postingDetail fixture extracts normalized descriptionText from a primary SuccessFactors/RMK-compatible HTML detail selector."
      },
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/successfactors/posting-detail-2002-fallback.html",
        "summary": "postingDetail fixture preserves failed primary-strategy diagnostics and succeeds through an ordered fallback HTML selector."
      }
    ]
  },
  "detect": {
    "recommendedAccessPathKey": "rmk_sitemap_html",
    "sourceConfig": {
      "baseUrl": "https://{{capture:successFactorsHost}}",
      "sitemapUrl": "https://{{capture:successFactorsHost}}/sitemap.xml"
    },
    "keyCandidates": ["{{capture:successFactorsHost|domainKey}}"],
    "nameCandidates": ["{{capture:successFactorsHost|domainTitle}}"],
    "inputUrlPatterns": [
      {
        "pattern": "(?i)^https?://(?<successFactorsHost>[A-Za-z0-9.-]+)/(?:job|go|career|careers)(?:/.*)?$",
        "captures": ["successFactorsHost"]
      },
      {
        "pattern": "(?i)^https?://(?<successFactorsHost>[A-Za-z0-9.-]+)/sitemap\\.xml(?:[?#].*)?$",
        "captures": ["successFactorsHost"]
      }
    ],
    "httpChecks": [
      {
        "key": "sitemap_contains_successfactors_job_urls",
        "url": "https://{{capture:successFactorsHost}}/sitemap.xml",
        "timeoutMs": 10000,
        "expectStatus": 200,
        "regex": "(?is)<loc>https?://[^<]+/job/[^<]+(?:-[0-9]+|/[0-9]+/?)(?:[?#][^<]*)?</loc>",
        "evidence": "Public sitemap contains SuccessFactors/RMK-style job detail URLs."
      }
    ],
    "evidence": [
      {
        "kind": "url",
        "message": "Common SAP SuccessFactors/RMK career sites expose posting URLs and sitemap URLs on one public host."
      },
      {
        "kind": "http",
        "message": "Profile execution expects a public XML sitemap containing job detail URLs."
      }
    ]
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": ["baseUrl", "sitemapUrl"],
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "format": "uri",
        "title": "Career site base URL"
      },
      "sitemapUrl": {
        "type": "string",
        "format": "uri",
        "title": "Sitemap URL"
      },
      "maxUrls": {
        "type": "number",
        "minimum": 1,
        "title": "Optional authoring note for desired maximum posting URLs"
      }
    }
  },
  "accessPaths": [
    {
      "key": "rmk_sitemap_html",
      "name": "RMK sitemap and HTML detail pages",
      "description": "Discover postings from a bounded public XML sitemap and load descriptions from SuccessFactors/RMK-style HTML detail pages with fallback selectors.",
      "postingDiscovery": {
        "strategies": [
          {
            "key": "sitemap_job_urls",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "{{sourceConfig:sitemapUrl}}",
              "headers": {
                "accept": "application/xml,text/xml"
              },
              "timeoutMs": 10000
            },
            "pagination": {
              "type": "sitemap",
              "postingUrlSelector": {
                "type": "sitemap_urls",
                "urlPattern": "(?i)/job/"
              },
              "limits": {
                "maxRequests": 1,
                "maxItems": 200
              }
            },
            "parse": { "type": "xml" },
            "select": { "type": "document" },
            "captures": {
              "location": {
                "from": {
                  "type": "item_field",
                  "key": "value",
                  "cardinality": "one"
                },
                "pattern": "(?i)/job/(?<value>[^/?#-]*_[^/?#-]*-[^/?#-]+|[^/?#-]+)-"
              },
              "title": {
                "from": {
                  "type": "item_field",
                  "key": "value",
                  "cardinality": "one"
                },
                "pattern": "(?i)/job/(?:[^/?#-]*_[^/?#-]*-[^/?#-]+|[^/?#-]+)-(?<value>.+?)(?:-[0-9]+|/[0-9]+/?)(?:[?#]|$)"
              },
              "jobId": {
                "from": {
                  "type": "item_field",
                  "key": "value",
                  "cardinality": "one"
                },
                "pattern": "(?i)(?:-|/)(?<value>[0-9]+)/?(?:[?#]|$)"
              },
              "externalPath": {
                "from": {
                  "type": "item_field",
                  "key": "value",
                  "cardinality": "one"
                },
                "pattern": "(?i)^https?://[^/]+(?<value>/job/[^?#]+)"
              }
            },
            "extract": {
              "fields": {
                "title": {
                  "type": "capture",
                  "key": "title",
                  "cardinality": "one",
                  "transforms": [
                    { "type": "url_decode" },
                    { "type": "slug_to_title" }
                  ]
                },
                "company": {
                  "type": "template",
                  "template": "{{source:name}}",
                  "cardinality": "one"
                },
                "url": {
                  "type": "item_field",
                  "key": "value",
                  "cardinality": "one"
                },
                "locations": {
                  "type": "capture",
                  "key": "location",
                  "cardinality": "one",
                  "transforms": [
                    { "type": "url_decode" },
                    { "type": "slug_to_title" }
                  ]
                },
                "postingMeta": {
                  "jobId": {
                    "type": "capture",
                    "key": "jobId",
                    "cardinality": "one"
                  },
                  "externalPath": {
                    "type": "capture",
                    "key": "externalPath",
                    "cardinality": "one"
                  }
                }
              }
            },
            "acceptWhen": {
              "requiredFields": [
                "title",
                "company",
                "url",
                "locations",
                "postingMeta.jobId",
                "postingMeta.externalPath"
              ],
              "minResults": 1
            }
          }
        ]
      },
      "postingDetail": {
        "strategies": [
          {
            "key": "primary_html_description",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "{{posting:url}}",
              "headers": {
                "accept": "text/html"
              },
              "timeoutMs": 10000
            },
            "parse": { "type": "html" },
            "select": { "type": "document" },
            "extract": {
              "fields": {
                "descriptionText": {
                  "type": "css_text",
                  "selector": "[data-automation-id='jobPostingDescription'], [data-automation-id*='job-description']",
                  "cardinality": "first",
                  "transforms": [{ "type": "normalize_whitespace" }]
                }
              }
            },
            "acceptWhen": {
              "minDescriptionLength": 40
            }
          },
          {
            "key": "fallback_html_description",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "{{posting:url}}",
              "headers": {
                "accept": "text/html"
              },
              "timeoutMs": 10000
            },
            "parse": { "type": "html" },
            "select": { "type": "document" },
            "extract": {
              "fields": {
                "descriptionText": {
                  "type": "css_text",
                  "selector": ".job-description__content, .job-description, .jobDescription, #job-description, main [class*='description']",
                  "cardinality": "first",
                  "transforms": [{ "type": "normalize_whitespace" }]
                }
              }
            },
            "acceptWhen": {
              "minDescriptionLength": 40
            }
          }
        ]
      }
    }
  ]
}
