{
  "schemaVersion": 1,
  "key": "phenom",
  "name": "Phenom",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [
      {
        "htmlContains": "phenom"
      },
      {
        "fetchText": {
          "url": "/sitemap_index.xml",
          "contains": "<sitemap"
        }
      }
    ]
  },
  "accessPaths": [
    {
      "key": "sitemap_inventory",
      "adapterKey": "declarative_sitemap_inventory",
      "availability": {
        "sourceConfig": {
          "url": "{{origin}}/sitemap_index.xml",
          "recursive": true
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "title": "Sitemap-URL"
          },
          "recursive": {
            "type": "boolean",
            "default": true,
            "title": "Sitemap-Index rekursiv auswerten"
          },
          "maxUrls": {
            "type": "number",
            "minimum": 1,
            "title": "Maximale URLs"
          }
        }
      },
      "inventory": {
        "fetch": {
          "url": "{{sourceConfig:url}}"
        },
        "parse": {
          "as": "xml"
        },
        "items": {
          "select": {
            "xmlText": "loc"
          },
          "where": [
            {
              "regex": "(?i)/job/"
            }
          ],
          "captures": [
            {
              "regex": "(?i)/job/(?:[^/]+/)?(?P<title>[^/?#]+?)/?$"
            }
          ]
        },
        "fields": {
          "title": {
            "template": "{{capture:title|urlDecode|slugToTitle}}"
          },
          "url": {
            "template": "{{itemText}}"
          },
          "company": {
            "template": "{{sourceName}}"
          },
          "locations": []
        }
      },
      "postingDetail": {
        "fetch": {
          "url": "{{posting:url}}"
        },
        "parse": {
          "as": "html"
        },
        "fields": {
          "descriptionText": {
            "selectorText": "[data-ph-at-id='jobdescription'], [data-ph-at-id='job-description'], .job-description, .jobDescription, #job-description"
          }
        }
      }
    }
  ]
}
