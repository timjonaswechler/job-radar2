{
  "schemaVersion": 3,
  "key": "greenhouse",
  "name": "Greenhouse",
  "kind": "recruiting_system",
  "description": "Greenhouse Job Board API profile for public board posting discovery and lazy posting detail extraction.",
  "support": {
    "level": "stable",
    "summary": "Maintained built-in Greenhouse Job Board API profile. Use Source Live Check on concrete Sources for current operational confidence.",
    "evidence": [
      {
        "kind": "manual_review",
        "reference": "https://developers.greenhouse.io/job-board.html",
        "summary": "Greenhouse exposes a public Job Board API with reusable board slug semantics."
      }
    ]
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": [
      "boardSlug"
    ],
    "additionalProperties": false,
    "properties": {
      "boardSlug": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$",
        "title": "Greenhouse board slug"
      }
    }
  },
  "accessPaths": [
    {
      "key": "boards_api",
      "name": "Greenhouse Boards API",
      "description": "Discover jobs from GET /v1/boards/{boardSlug}/jobs and load one posting from GET /v1/boards/{boardSlug}/jobs/{jobId}.",
      "discovery": {
        "strategies": [
          {
            "key": "jobs_api",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "https://boards-api.greenhouse.io/v1/boards/{{sourceConfig:boardSlug}}/jobs",
              "headers": {
                "accept": "application/json"
              },
              "timeoutMs": 10000
            },
            "parse": {
              "type": "json"
            },
            "select": {
              "type": "json_path",
              "jsonPath": "$.jobs"
            },
            "extract": {
              "reference": {
                "url": {
                  "type": "json_path",
                  "jsonPath": "$.absolute_url",
                  "cardinality": "one"
                },
                "providerPostingId": {
                  "type": "json_path",
                  "jsonPath": "$.id",
                  "cardinality": "one",
                  "transforms": [
                    {
                      "type": "to_string"
                    }
                  ]
                }
              },
              "providerValues": {
                "title": {
                  "type": "json_path",
                  "jsonPath": "$.title",
                  "cardinality": "one",
                  "transforms": [
                    {
                      "type": "to_string"
                    },
                    {
                      "type": "trim"
                    }
                  ]
                },
                "company": {
                  "type": "template",
                  "template": "{{source:name}}",
                  "cardinality": "one"
                },
                "locations": {
                  "type": "json_path",
                  "jsonPath": "$.location.name",
                  "cardinality": "optional"
                }
              },
              "postingMeta": {
                "jobId": {
                  "type": "json_path",
                  "jsonPath": "$.id",
                  "cardinality": "one",
                  "transforms": [
                    {
                      "type": "to_string"
                    }
                  ]
                }
              }
            },
            "acceptWhen": {
              "requiredFields": [
                "title",
                "company",
                "url",
                "postingMeta.jobId"
              ],
              "minResults": 1
            }
          }
        ],
        "policy": {
          "type": "first_accepted"
        }
      },
      "detail": {
        "strategies": [
          {
            "key": "job_detail_api",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "https://boards-api.greenhouse.io/v1/boards/{{sourceConfig:boardSlug}}/jobs/{{postingMeta:jobId}}",
              "headers": {
                "accept": "application/json"
              },
              "timeoutMs": 10000
            },
            "parse": {
              "type": "json"
            },
            "select": {
              "type": "document"
            },
            "extract": {
              "fields": {
                "descriptionText": {
                  "type": "json_path",
                  "jsonPath": "$.content",
                  "cardinality": "one",
                  "transforms": [
                    {
                      "type": "to_string"
                    },
                    {
                      "type": "html_to_text"
                    },
                    {
                      "type": "normalize_whitespace"
                    }
                  ]
                }
              }
            },
            "acceptWhen": {
              "minDescriptionLength": 20
            }
          }
        ],
        "policy": {
          "type": "first_accepted"
        }
      }
    }
  ],
  "detection": {
    "policy": {
      "type": "all_required"
    },
    "strategies": [
      {
        "type": "url",
        "key": "input_url",
        "input": {
          "type": "pattern_alternatives",
          "alternatives": [
            {
              "pattern": "(?i)^https?://(?:boards|job-boards)\\.greenhouse\\.io/(?<boardSlug>[a-z0-9][a-z0-9_-]*)(?:[/?#].*)?$",
              "captures": [
                "boardSlug"
              ]
            },
            {
              "pattern": "(?i)^https?://boards-api\\.greenhouse\\.io/v1/boards/(?<boardSlug>[a-z0-9][a-z0-9_-]*)(?:/(?:jobs|departments|offices|sections).*)?$",
              "captures": [
                "boardSlug"
              ]
            }
          ]
        }
      }
    ],
    "recommendedAccessPathKey": "boards_api",
    "sourceConfig": {
      "boardSlug": "{{capture:boardSlug}}"
    },
    "keyCandidates": [
      "{{capture:boardSlug}}"
    ],
    "nameCandidates": [
      "{{capture:boardSlug}}"
    ],
    "evidence": [
      {
        "kind": "url",
        "message": "Greenhouse board URLs and Boards API URLs include a reusable board slug."
      }
    ]
  }
}
