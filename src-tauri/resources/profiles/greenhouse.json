{
  "schemaVersion": 2,
  "key": "greenhouse",
  "name": "Greenhouse",
  "kind": "recruiting_system",
  "description": "Greenhouse Job Board API profile for public board posting discovery and lazy posting detail extraction.",
  "support": {
    "level": "verified",
    "summary": "Verified against deterministic offline Greenhouse Job Board API-compatible discovery and detail fixtures.",
    "evidence": [
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/greenhouse/posting-discovery-response.json",
        "summary": "postingDiscovery fixture executes through the public Profile Compiler and shared Profile DSL runtime."
      },
      {
        "kind": "fixture",
        "reference": "src-tauri/tests/fixtures/greenhouse/posting-detail-9001-response.json",
        "summary": "postingDetail fixture extracts normalized descriptionText from HTML-in-JSON content through the shared Profile DSL runtime."
      }
    ]
  },
  "detect": {
    "recommendedAccessPathKey": "boards_api",
    "sourceConfig": {
      "boardSlug": "{{capture:boardSlug}}"
    },
    "keyCandidates": ["{{capture:boardSlug}}"],
    "nameCandidates": ["{{capture:boardSlug}}"],
    "inputUrlPatterns": [
      {
        "pattern": "(?i)^https?://(?:boards|job-boards)\\.greenhouse\\.io/(?<boardSlug>[a-z0-9][a-z0-9_-]*)(?:[/?#].*)?$",
        "captures": ["boardSlug"]
      },
      {
        "pattern": "(?i)^https?://boards-api\\.greenhouse\\.io/v1/boards/(?<boardSlug>[a-z0-9][a-z0-9_-]*)(?:/(?:jobs|departments|offices|sections).*)?$",
        "captures": ["boardSlug"]
      }
    ],
    "evidence": [
      {
        "kind": "url",
        "message": "Greenhouse board URLs and Boards API URLs include a reusable board slug."
      }
    ]
  },
  "sourceConfigSchema": {
    "type": "object",
    "required": ["boardSlug"],
    "additionalProperties": false,
    "properties": {
      "boardSlug": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$",
        "title": "Greenhouse board slug"
      }
    }
  },
  "accessPaths": [
    {
      "key": "boards_api",
      "name": "Greenhouse Boards API",
      "description": "Discover jobs from GET /v1/boards/{boardSlug}/jobs and load one posting from GET /v1/boards/{boardSlug}/jobs/{jobId}.",
      "postingDiscovery": {
        "strategies": [
          {
            "key": "jobs_api",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "https://boards-api.greenhouse.io/v1/boards/{{sourceConfig:boardSlug}}/jobs",
              "headers": {
                "accept": "application/json"
              },
              "timeoutMs": 10000
            },
            "parse": { "type": "json" },
            "select": {
              "type": "json_path",
              "jsonPath": "$.jobs"
            },
            "extract": {
              "fields": {
                "title": {
                  "type": "json_path",
                  "jsonPath": "$.title",
                  "cardinality": "one",
                  "transforms": [{ "type": "trim" }]
                },
                "company": {
                  "type": "template",
                  "template": "{{source:name}}",
                  "cardinality": "one"
                },
                "url": {
                  "type": "json_path",
                  "jsonPath": "$.absolute_url",
                  "cardinality": "one"
                },
                "locations": {
                  "type": "json_path",
                  "jsonPath": "$.location.name",
                  "cardinality": "optional"
                },
                "postingMeta": {
                  "jobId": {
                    "type": "json_path",
                    "jsonPath": "$.id",
                    "cardinality": "one",
                    "transforms": [{ "type": "to_string" }]
                  }
                }
              }
            },
            "acceptWhen": {
              "requiredFields": ["title", "company", "url", "postingMeta.jobId"],
              "minResults": 1
            }
          }
        ]
      },
      "postingDetail": {
        "strategies": [
          {
            "key": "job_detail_api",
            "fetch": {
              "mode": "http",
              "method": "GET",
              "url": "https://boards-api.greenhouse.io/v1/boards/{{sourceConfig:boardSlug}}/jobs/{{postingMeta:jobId}}",
              "headers": {
                "accept": "application/json"
              },
              "timeoutMs": 10000
            },
            "parse": { "type": "json" },
            "select": { "type": "document" },
            "extract": {
              "fields": {
                "descriptionText": {
                  "type": "json_path",
                  "jsonPath": "$.content",
                  "cardinality": "one",
                  "transforms": [
                    { "type": "html_to_text" },
                    { "type": "normalize_whitespace" }
                  ]
                }
              }
            },
            "acceptWhen": {
              "minDescriptionLength": 20
            }
          }
        ]
      }
    }
  ]
}
