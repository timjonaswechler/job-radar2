{
  "schemaVersion": 1,
  "key": "greenhouse",
  "name": "Greenhouse",
  "kind": "recruiting_system",
  "detect": {
    "phases": ["http"],
    "required": [
      {
        "htmlRegex": "(?i)https?://(?:(?:boards|job-boards)\\.greenhouse\\.io/(?:embed/job_board(?:/js)?\\?[^\\\"'<>\\s]*\\bfor=)?|boards-api\\.greenhouse\\.io/v1/boards/)([a-z0-9][a-z0-9_-]*)(?:(?:/(?:jobs|departments|offices|sections)[^\\\"'<>\\s]*)|(?:/[?#&\\\"'<>\\s]?)|[?#&\\\"'<>\\s]|$)",
        "captureAs": "boardSlug"
      }
    ]
  },
  "identity": {
    "keyCandidates": [
      "{{capture:boardSlug|technicalKey}}"
    ],
    "nameCandidates": [
      "{{capture:boardSlug|titleCase}}"
    ]
  },
  "accessPaths": [
    {
      "key": "endpoint_inventory",
      "adapterKey": "declarative_endpoint_inventory",
      "availability": {
        "requiredCaptures": ["boardSlug"],
        "sourceConfig": {
          "boardSlug": "{{capture:boardSlug}}",
          "startUrl": "{{inputUrl}}"
        }
      },
      "sourceConfigSchema": {
        "type": "object",
        "required": ["boardSlug"],
        "additionalProperties": false,
        "properties": {
          "boardSlug": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$",
            "title": "Greenhouse board token"
          },
          "startUrl": {
            "type": "string",
            "format": "uri",
            "title": "Start-URL"
          }
        }
      },
      "inventory": {
        "fetch": {
          "url": "https://boards-api.greenhouse.io/v1/boards/{{sourceConfig:boardSlug}}/jobs"
        },
        "parse": {
          "as": "json"
        },
        "items": {
          "select": {
            "jsonPath": "$.jobs"
          }
        },
        "fields": {
          "title": {
            "jsonPath": "$.title"
          },
          "url": {
            "jsonPath": "$.absolute_url"
          },
          "company": {
            "template": "{{sourceName}}"
          },
          "locations": [
            {
              "jsonPath": "$.location.name"
            }
          ],
          "postingMeta": {
            "jobId": {
              "jsonPath": "$.id"
            }
          }
        }
      },
      "postingDetail": {
        "fetch": {
          "url": "https://boards-api.greenhouse.io/v1/boards/{{sourceConfig:boardSlug}}/jobs/{{postingMeta:jobId}}"
        },
        "parse": {
          "as": "json"
        },
        "fields": {
          "descriptionText": {
            "jsonPathHtml": "$.content"
          }
        }
      }
    }
  ]
}
