          "company",
          "url",
          "locations",
          "postingMeta"
        ],
        "containsCandidates": [
          {
            "title": "Senior Platform Engineer",
            "company": "Workday Recruiting fixture verification",
            "url": "https://acme.wd3.myworkdayjobs.com/en-US/External/job/Germany-Berlin/Senior-Platform-Engineer_JR-1001",
            "locations": [
              "Berlin, Germany"
            ],
            "postingMeta": {
              "externalPath": "/job/Germany-Berlin/Senior-Platform-Engineer_JR-1001"
            }
          }
        ]
      }
    },
    "postingDetail": {
      "cases": [
        {
          "key": "job_jr_1001_detail",
          "posting": {
            "title": "Senior Platform Engineer",
            "company": "Workday Recruiting fixture verification",
            "url": "https://acme.wd3.myworkdayjobs.com/en-US/External/job/Germany-Berlin/Senior-Platform-Engineer_JR-1001",
            "postingMeta": {
              "externalPath": "/job/Germany-Berlin/Senior-Platform-Engineer_JR-1001"
            }
          },
          "expect": {
            "minDescriptionLength": 60,
            "descriptionContains": [
              "internal developer platforms",
