        "headers": {
          "content-type": "application/json"
        },
        "bodyFile": "responses/posting-discovery-page-0-response.json"
      }
    },
    {
      "key": "detail_job_jr_1001",
      "match": {
        "method": "GET",
        "url": "https://acme.wd3.myworkdayjobs.com/wday/cxs/acme/External/job/Germany-Berlin/Senior-Platform-Engineer_JR-1001"
      },
      "response": {
        "status": 200,
        "headers": {
          "content-type": "application/json"
        },
        "bodyFile": "responses/posting-detail-jr-1001-response.json"
      }
    }
  ],
  "checks": {
