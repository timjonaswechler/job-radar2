{
  "schemaVersion": 1,
  "profileKey": "workday",
  "accessPathKey": "cxs_api",
  "sourceConfig": {
    "workdayHost": "acme.wd3.myworkdayjobs.com",
    "tenant": "acme",
    "site": "External",
    "startUrl": "https://acme.wd3.myworkdayjobs.com/en-US/External"
  },
  "requests": [
