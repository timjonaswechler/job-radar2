{
  "schemaVersion": 1,
  "profileKey": "successfactors",
  "accessPathKey": "rmk_sitemap_html",
  "sourceConfig": {
    "baseUrl": "https://jobs.example-successfactors.test",
    "sitemapUrl": "https://jobs.example-successfactors.test/sitemap.xml"
  },
  "requests": [
    {
      "key": "discovery_sitemap",
      "match": {
        "method": "GET",
        "url": "https://jobs.example-successfactors.test/sitemap.xml"
      },
      "response": {
        "status": 200,
        "headers": {
          "content-type": "application/xml"
        },
        "bodyFile": "responses/posting-discovery-sitemap.xml"
      }
    },
    {
      "key": "detail_job_1001",
      "match": {
        "method": "GET",
        "url": "https://jobs.example-successfactors.test/job/berlin-senior-platform-engineer-1001"
      },
      "response": {
        "status": 200,
        "headers": {
          "content-type": "text/html"
        },
        "bodyFile": "responses/posting-detail-1001-primary.html"
      }
    }
  ],
  "checks": {
    "postingDiscovery": {
      "expect": {
        "minCandidates": 4,
        "requiredFields": ["title", "company", "url", "locations", "postingMeta"],
        "containsCandidates": [
          {
            "title": "Senior Platform Engineer",
            "company": "SAP SuccessFactors fixture verification",
            "url": "https://jobs.example-successfactors.test/job/berlin-senior-platform-engineer-1001",
            "locations": ["Berlin"],
            "postingMeta": {
              "jobId": "1001",
              "externalPath": "/job/berlin-senior-platform-engineer-1001"
            }
          }
        ]
      }
    },
    "postingDetail": {
      "cases": [
        {
          "key": "job_1001_detail",
          "posting": {
            "title": "Senior Platform Engineer",
            "company": "SAP SuccessFactors fixture verification",
            "url": "https://jobs.example-successfactors.test/job/berlin-senior-platform-engineer-1001",
            "postingMeta": {
              "jobId": "1001",
              "externalPath": "/job/berlin-senior-platform-engineer-1001"
            }
          },
          "expect": {
            "minDescriptionLength": 60,
            "descriptionContains": ["recruiting platform integrations", "Rust"]
          }
        }
      ]
    }
  }
}
